# Secret pour les données sensibles du backend
#
# IMPORTANT:
# 1. Copiez ce fichier vers backend-secret.yaml
# 2. Remplacez les valeurs placeholder par vos vraies valeurs encodées en base64
#
# Pour encoder une valeur: echo -n 'votre_valeur' | base64
#
# OU utilisez la commande kubectl directement (recommandé):
#   kubectl create secret generic backend-secret \
#     --namespace=model-platform \
#     --from-literal=POSTGRES_PASSWORD='your_password' \
#     --from-literal=JWT_SECRET='your_jwt_secret' \
#     --from-literal=ADMIN_EMAIL='admin@example.com' \
#     --from-literal=ADMIN_PASSWORD='your_admin_password'
---
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: model-platform
type: Opaque
data:
  # Remplacez par vos valeurs encodées en base64
  POSTGRES_PASSWORD: <BASE64_ENCODED_PASSWORD>
  JWT_SECRET: <BASE64_ENCODED_JWT_SECRET>
  ADMIN_EMAIL: <BASE64_ENCODED_EMAIL>
  ADMIN_PASSWORD: <BASE64_ENCODED_ADMIN_PASSWORD>
